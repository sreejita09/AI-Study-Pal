import { useState, useRef, useEffect } from "react";
import {
  Plus, FileText, BookOpen, ChevronLeft, ChevronRight, ChevronDown,
  LogOut, AlignLeft, StickyNote, HelpCircle, Search, X, Trash2, Pencil, Check
} from "lucide-react";

const TYPE_ICONS = { summary: AlignLeft, notes: StickyNote, quiz: HelpCircle };
const TYPE_COLORS = { summary: "text-blue-400", notes: "text-purple-400", quiz: "text-green-400" };
const TYPE_LABELS = { summary: "Summary", notes: "Notes", quiz: "Quiz" };

function timeAgo(ts) {
  if (!ts) return "";
  try {
    const diff = Date.now() - new Date(ts).getTime();
    if (diff < 0 || isNaN(diff)) return ts;
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return "Just now";
    if (mins < 60) return `${mins}m ago`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `${hrs}h ago`;
    const days = Math.floor(hrs / 24);
    if (days < 7) return `${days}d ago`;
    return ts;
  } catch {
    return ts;
  }
}

export default function DashboardSidebar({
  sessions = [],
  studyPlans = [],
  activeSessionId,
  activeTab = "recent",
  onTabChange,
  onNewStudy,
  onSelectSession,
  onSelectHistory,
  onDeleteSession,
  onRenameSession,
  onLogout,
  collapsed,
  onToggleCollapse,
  history = []
}) {
  const tab = activeTab;
  const setTab = (t) => onTabChange?.(t);

  const [searchQuery, setSearchQuery] = useState("");
  const [filesOpen, setFilesOpen] = useState(true);
  const [historyOpen, setHistoryOpen] = useState(true);
  const [plansOpen, setPlansOpen] = useState(true);
  const [deleteTarget, setDeleteTarget] = useState(null);
  const [editingId, setEditingId] = useState(null);
  const [editValue, setEditValue] = useState("");
  const renameRef = useRef(null);

  useEffect(() => {
    if (editingId && renameRef.current) {
      renameRef.current.focus();
      renameRef.current.select();
    }
  }, [editingId]);

  const startRename = (e, item) => {
    e.stopPropagation();
    setEditingId(item.id);
    setEditValue(item.title || "");
  };

  const commitRename = (id) => {
    const trimmed = editValue.trim();
    if (trimmed && onRenameSession) {
      onRenameSession(id, trimmed);
    }
    setEditingId(null);
  };

  // Group history by sessionId
  const sessionHistory = {};
  history.forEach((h) => {
    if (h.sessionId) {
      if (!sessionHistory[h.sessionId]) sessionHistory[h.sessionId] = [];
      sessionHistory[h.sessionId].push(h);
    }
  });

  // Collapsed sidebar
  if (collapsed) {
    return (
      <aside className="flex h-screen w-16 flex-col items-center border-r border-gray-800 bg-[#0f0f0f] py-4">
        <button
          onClick={onToggleCollapse}
          className="mb-6 rounded-lg bg-white/5 p-2 text-zinc-400 transition hover:bg-gray-800 hover:text-white"
        >
          <ChevronRight size={18} />
        </button>
        <button
          onClick={onNewStudy}
          className="mb-4 rounded-lg bg-yellow-500 p-2.5 text-black transition-all hover:bg-yellow-400"
        >
          <Plus size={18} />
        </button>
        <div className="mt-auto">
          <button onClick={onLogout} className="rounded-lg p-2 text-zinc-500 transition hover:text-red-400">
            <LogOut size={18} />
          </button>
        </div>
      </aside>
    );
  }

  const q = searchQuery.toLowerCase().trim();

  const filteredSessions = q
    ? sessions.filter((s) => s.title?.toLowerCase().includes(q))
    : sessions;

  const filteredPlans = q
    ? studyPlans.filter((p) => p.title?.toLowerCase().includes(q))
    : studyPlans;

  return (
    <aside className="flex h-screen w-64 flex-col border-r border-gray-800 bg-[#0f0f0f]">
      {/* Header */}
      <div className="flex items-center justify-between border-b border-gray-800 px-4 py-4">
        <h2 className="font-display text-lg font-bold tracking-wide text-white">AI Study Pal</h2>
        <button
          onClick={onToggleCollapse}
          className="rounded-lg p-1.5 text-zinc-500 transition hover:bg-gray-800 hover:text-white"
        >
          <ChevronLeft size={16} />
        </button>
      </div>

      {/* New Study Button */}
      <div className="px-3 mt-4 mb-3">
        <button
          onClick={onNewStudy}
          className="flex w-full items-center justify-center gap-1.5 rounded-lg bg-yellow-500 py-2 text-sm font-semibold text-black transition-all hover:bg-yellow-400 active:scale-[0.98]"
        >
          <Plus size={14} />
          New Study
        </button>
      </div>

      {/* Search Bar */}
      <div className="px-3 mb-3">
        <div className="relative">
          <Search size={14} className="absolute left-2.5 top-1/2 -translate-y-1/2 text-zinc-600" />
          <input
            type="text"
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
            placeholder="Search files & history..."
            className="w-full rounded-lg border border-gray-800 bg-gray-900/50 py-2 pl-8 pr-8 text-xs text-white placeholder:text-zinc-600 outline-none transition focus:border-yellow-400/40 focus:bg-gray-900"
          />
          {searchQuery && (
            <button
              onClick={() => setSearchQuery("")}
              className="absolute right-2 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-white"
            >
              <X size={12} />
            </button>
          )}
        </div>
      </div>

      {/* Tabs */}
      <div className="flex border-b border-gray-800 px-3">
        <button
          onClick={() => setTab("recent")}
          className={`flex-1 border-b-2 px-3 py-2.5 text-xs font-semibold uppercase tracking-wide transition ${
            tab === "recent"
              ? "border-yellow-400 text-white"
              : "border-transparent text-gray-400 hover:text-zinc-300"
          }`}
        >
          Recent
        </button>
        <button
          onClick={() => setTab("plans")}
          className={`flex-1 border-b-2 px-3 py-2.5 text-xs font-semibold uppercase tracking-wide transition ${
            tab === "plans"
              ? "border-yellow-400 text-white"
              : "border-transparent text-gray-400 hover:text-zinc-300"
          }`}
        >
          Plans
        </button>
      </div>

      {/* Scrollable Content */}
      <div className="flex-1 overflow-y-auto px-3 py-2">
        {tab === "recent" ? (
          <>
            {/* FILES Section — each file is a session with its own history */}
            <SectionHeader
              label="FILES"
              open={filesOpen}
              onToggle={() => setFilesOpen((o) => !o)}
              count={filteredSessions.length}
            />
            {filesOpen && (
              <ul className="mb-2 space-y-0.5">
                {filteredSessions.length === 0 ? (
                  <p className="px-3 py-4 text-center text-xs text-zinc-600">
                    {q ? "No matching files" : "No files uploaded yet"}
                  </p>
                ) : (
                  filteredSessions.map((item) => {
                    const isActive = activeSessionId === item.id;
                    const isEditing = editingId === item.id;
                    const itemHistory = sessionHistory[item.id] || [];

                    return (
                      <li key={item.id}>
                        {/* File row */}
                        <div
                          onClick={() => !isEditing && onSelectSession(item.id)}
                          className={`group relative flex w-full cursor-pointer items-center gap-2 rounded-lg px-3 py-2 text-left transition-all duration-150 ${
                            isActive
                              ? "border border-yellow-400 bg-gray-800 text-white shadow-[0_0_8px_rgba(250,204,21,0.12)]"
                              : "border border-transparent text-zinc-400 hover:bg-gray-800 hover:text-white"
                          }`}
                        >
                          <FileText size={14} className={`shrink-0 ${isActive ? "text-yellow-400" : "text-zinc-500"}`} />
                          <div className="min-w-0 flex-1">
                            {isEditing ? (
                              <form
                                onSubmit={(e) => { e.preventDefault(); commitRename(item.id); }}
                                className="flex items-center gap-1"
                              >
                                <input
                                  ref={renameRef}
                                  value={editValue}
                                  onChange={(e) => setEditValue(e.target.value)}
                                  onBlur={() => commitRename(item.id)}
                                  onKeyDown={(e) => { if (e.key === "Escape") setEditingId(null); }}
                                  className="w-full rounded bg-gray-700 px-1.5 py-0.5 text-sm text-white outline-none ring-1 ring-yellow-400/40"
                                />
                                <button type="submit" className="shrink-0 text-green-400">
                                  <Check size={12} />
                                </button>
                              </form>
                            ) : (
                              <>
                                <p className="truncate text-sm font-medium">{item.title}</p>
                                <p className="text-[11px] text-zinc-600">{timeAgo(item.timestamp)}</p>
                              </>
                            )}
                          </div>
                          {/* Hover actions: rename + delete */}
                          {!isEditing && (
                            <div className="flex shrink-0 items-center gap-0.5 opacity-0 transition-opacity group-hover:opacity-100">
                              <button
                                onClick={(e) => startRename(e, item)}
                                className="rounded p-1 text-zinc-500 hover:bg-gray-700 hover:text-yellow-400"
                                title="Rename"
                              >
                                <Pencil size={12} />
                              </button>
                              <button
                                onClick={(e) => { e.stopPropagation(); setDeleteTarget(item); }}
                                className="rounded p-1 text-red-500 hover:bg-red-500/10 hover:text-red-400"
                                title="Delete session"
                              >
                                <Trash2 size={12} />
                              </button>
                            </div>
                          )}
                        </div>

                        {/* Session-grouped history (shown under active file) */}
                        {isActive && itemHistory.length > 0 && (
                          <ul className="ml-5 mt-0.5 space-y-0.5 border-l border-gray-800 pl-2">
                            {itemHistory.slice(0, 10).map((h, i) => {
                              const Icon = TYPE_ICONS[h.type] || FileText;
                              const color = TYPE_COLORS[h.type] || "text-zinc-400";
                              return (
                                <li key={i}>
                                  <button
                                    onClick={(e) => {
                                      e.stopPropagation();
                                      onSelectHistory?.(h);
                                    }}
                                    className="flex w-full items-center gap-2 rounded-md px-2 py-1.5 text-left transition-all duration-150 text-zinc-500 hover:bg-gray-800 hover:text-white"
                                  >
                                    <Icon size={12} className={`shrink-0 ${color}`} />
                                    <span className="truncate text-xs font-medium">
                                      {TYPE_LABELS[h.type] || h.type}
                                    </span>
                                    <span className="ml-auto text-[10px] text-zinc-700 shrink-0">{timeAgo(h.timestamp)}</span>
                                  </button>
                                </li>
                              );
                            })}
                          </ul>
                        )}
                      </li>
                    );
                  })
                )}
              </ul>
            )}

            {/* HISTORY Section — all recent generations */}
            <SectionHeader
              label="HISTORY"
              open={historyOpen}
              onToggle={() => setHistoryOpen((o) => !o)}
              count={history.length}
            />
            {historyOpen && (
              <ul className="mb-2 space-y-0.5">
                {history.length === 0 ? (
                  <p className="px-3 py-4 text-center text-xs text-zinc-600">
                    {q ? "No matching history" : "No generations yet"}
                  </p>
                ) : (
                  history.slice(0, 20).map((h, i) => {
                    const Icon = TYPE_ICONS[h.type] || FileText;
                    const color = TYPE_COLORS[h.type] || "text-zinc-400";
                    const session = sessions.find((s) => s.id === h.sessionId);
                    if (q && !(h.type?.toLowerCase().includes(q) || TYPE_LABELS[h.type]?.toLowerCase().includes(q) || session?.title?.toLowerCase().includes(q))) {
                      return null;
                    }
                    return (
                      <li key={i}>
                        <button
                          onClick={() => onSelectHistory?.(h)}
                          className="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left transition-all duration-150 border border-transparent text-zinc-400 hover:bg-gray-800 hover:text-white"
                        >
                          <Icon size={14} className={`shrink-0 ${color}`} />
                          <div className="min-w-0 flex-1">
                            <p className="truncate text-sm font-medium">
                              {TYPE_LABELS[h.type] || h.type}
                            </p>
                            <p className="text-[11px] text-zinc-600">
                              {session?.title ? `${session.title} · ` : ""}{timeAgo(h.timestamp)}
                            </p>
                          </div>
                        </button>
                      </li>
                    );
                  })
                )}
              </ul>
            )}
          </>
        ) : (
          <>
            {/* PLANS Section */}
            <SectionHeader
              label="STUDY PLANS"
              open={plansOpen}
              onToggle={() => setPlansOpen((o) => !o)}
              count={filteredPlans.length}
            />
            {plansOpen && (
              <ul className="mb-2 space-y-0.5">
                {filteredPlans.length === 0 ? (
                  <p className="px-3 py-4 text-center text-xs text-zinc-600">
                    {q ? "No matching plans" : "No study plans yet"}
                  </p>
                ) : (
                  filteredPlans.map((item) => (
                    <li key={item.id}>
                      <button
                        onClick={() => onSelectSession(item.id)}
                        className="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left transition-all duration-150 border border-transparent text-zinc-400 hover:bg-gray-800 hover:text-white"
                      >
                        <BookOpen size={14} className="shrink-0 text-zinc-500" />
                        <div className="min-w-0 flex-1">
                          <p className="truncate text-sm font-medium">{item.title}</p>
                          <p className="text-[11px] text-zinc-600">{timeAgo(item.timestamp)}</p>
                        </div>
                      </button>
                    </li>
                  ))
                )}
              </ul>
            )}
          </>
        )}
      </div>

      {/* Sign Out */}
      <div className="border-t border-gray-800 p-3">
        <button
          onClick={onLogout}
          className="flex w-full items-center gap-2 rounded-lg px-3 py-2.5 text-sm text-zinc-500 transition hover:bg-gray-800 hover:text-red-400"
        >
          <LogOut size={16} />
          Sign out
        </button>
      </div>

      {/* Delete Confirmation Modal */}
      {deleteTarget && (
        <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
          <div className="w-full max-w-sm rounded-2xl border border-white/10 bg-[#1a1a1a] p-6 shadow-xl">
            <h3 className="text-lg font-semibold text-white">Delete study session?</h3>
            <p className="mt-2 text-sm text-zinc-400">
              Are you sure you want to delete <span className="font-medium text-white">"{deleteTarget.title}"</span>?
              This will remove the file and all related history (summaries, notes, quizzes).
            </p>
            <div className="mt-5 flex justify-end gap-3">
              <button
                onClick={() => setDeleteTarget(null)}
                className="rounded-lg border border-white/10 px-4 py-2 text-sm text-zinc-400 transition hover:bg-white/5"
              >
                Cancel
              </button>
              <button
                onClick={() => {
                  onDeleteSession?.(deleteTarget.id);
                  setDeleteTarget(null);
                }}
                className="rounded-lg bg-red-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-600"
              >
                Delete
              </button>
            </div>
          </div>
        </div>
      )}
    </aside>
  );
}

/* Collapsible section header */
function SectionHeader({ label, open, onToggle, count = 0 }) {
  return (
    <button
      onClick={onToggle}
      className="mt-3 mb-1.5 flex w-full items-center justify-between px-1 group"
    >
      <span className="text-[10px] font-semibold uppercase tracking-widest text-zinc-500 group-hover:text-zinc-300 transition">
        {label}
        {count > 0 && (
          <span className="ml-1.5 text-zinc-700">{count}</span>
        )}
      </span>
      <ChevronDown
        size={12}
        className={`text-zinc-600 transition-transform duration-200 group-hover:text-zinc-400 ${
          open ? "rotate-0" : "-rotate-90"
        }`}
      />
    </button>
  );
}
