PORT=5000

# MongoDB — use MONGO_URI on Render, MONGODB_URI also accepted
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/ai-study-pal
MONGODB_URI=mongodb://127.0.0.1:27017/ai-study-pal

# Frontend origin — set to your Vercel URL in Render env vars
CLIENT_URL=http://localhost:5173

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d
COOKIE_NAME=aistudypal_token

# OpenAI — get from platform.openai.com/api-keys
OPENAI_API_KEY=

# Gmail SMTP — use a Gmail App Password (not your account password)
# Create at: myaccount.google.com/apppasswords (requires 2FA enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
