# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database (use PostgreSQL in production, not SQLite)
# For development with SQLite:
# DATABASE_URL=sqlite:///study_pal.db
# For production with PostgreSQL:
DATABASE_URL=postgresql://user:password@localhost:5432/ai_study_pal

# Email Configuration (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@aisstudypal.com

# Security
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Optional: Third-party services
# OPENAI_API_KEY=your-openai-key-for-enhanced-features
